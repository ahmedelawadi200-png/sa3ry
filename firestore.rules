rules_version = '2';

// ==================== SA3RY FIRESTORE SECURITY RULES ====================
// Deploy with: firebase deploy --only firestore:rules
//
// SECURITY MODEL:
// - Anyone (including signed-out users) can READ products - it's a public
//   price-comparison catalog.
// - Only a verified admin (a user whose UID has a document at /admins/{uid})
//   can create, update, or delete products.
// - This is the enforcement layer the client-side "isAdminUser" check in
//   firebase.js cannot bypass, even from the browser DevTools console -
//   any write from a non-admin UID is rejected by Firestore itself.
// - The /admins collection can never be written by clients at all: admin
//   grants must be made from the Firebase Console or a trusted backend
//   (e.g. a Cloud Function with the Admin SDK), never from client code.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isNonEmptyString(value, maxLength) {
      return value is string &&
        value.size() > 0 &&
        value.size() <= maxLength;
    }

    function isOptionalString(data, field, maxLength) {
      return !data.keys().hasAny([field]) ||
        data[field] == null ||
        (data[field] is string && data[field].size() <= maxLength);
    }

    function hasValidProductShape() {
      return request.resource.data.keys().hasAll(['name', 'brand', 'category', 'stores']) &&
        isNonEmptyString(request.resource.data.name, 160) &&
        isNonEmptyString(request.resource.data.brand, 80) &&
        isNonEmptyString(request.resource.data.category, 40) &&
        request.resource.data.stores is list &&
        request.resource.data.stores.size() > 0 &&
        request.resource.data.stores.size() <= 20;
    }

    function hasValidStoreShape() {
      return request.resource.data.keys().hasAll(['name', 'active']) &&
        isNonEmptyString(request.resource.data.name, 120) &&
        request.resource.data.active is bool &&
        isOptionalString(request.resource.data, 'logo', 500) &&
        isOptionalString(request.resource.data, 'website', 500) &&
        isOptionalString(request.resource.data, 'phone', 40) &&
        isOptionalString(request.resource.data, 'email', 120) &&
        isOptionalString(request.resource.data, 'address', 300) &&
        isOptionalString(request.resource.data, 'color', 20);
    }

    // ---- Products: public catalog, admin-only writes ----
    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() && hasValidProductShape();
      allow delete: if isAdmin();
    }

    // ---- Stores: public store metadata, admin-only writes ----
    match /stores/{storeId} {
      allow read: if true;
      allow create, update: if isAdmin() && hasValidStoreShape();
      allow delete: if isAdmin();
    }

    // ---- Admins: never writable from the client. Manage via Console/Admin SDK only. ----
    match /admins/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid; // a user may check their own status
      allow write: if false;
    }

    // ---- Reviews/comments: any signed-in user may write their own review,
    //      anyone may read, only the author or an admin may edit/delete it. ----
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isSignedIn() &&
        (resource.data.uid == request.auth.uid || isAdmin());
    }

    // ---- Provider runs: written ONLY by the Cloud Functions backend using
    //      the Admin SDK, which bypasses these rules entirely - so there is
    //      no "allow write" here on purpose, a client (even an admin) can
    //      never fake a run's status. Admins can read them for the health
    //      dashboard; nobody else needs to see internal sync diagnostics. ----
    match /providerRuns/{runId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ---- Review queue: ambiguous product matches (75%-85% similarity)
    //      from the price-sync backend. Written by the Admin SDK backend;
    //      admins may update status (confirm/reject) from the review-queue
    //      UI, but never create/delete entries directly - those only come
    //      from an actual sync run. ----
    match /reviewQueue/{itemId} {
      allow read: if isAdmin();
      allow create, delete: if false;
      allow update: if isAdmin() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'resolvedAt']) &&
        request.resource.data.status in ['confirmed', 'rejected'];
    }

    // ---- Everything else: locked down by default. ----
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
